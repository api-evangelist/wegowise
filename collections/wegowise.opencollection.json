  "items": [
    {
      "info": {
        "name": "Utility Companies",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Supported Utility Companies",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://www.wegowise.com/api/v1/utility_companies",
            "params": [
              {
                "name": "state",
                "value": "",
                "type": "query",
                "description": "Filter by US state code (e.g., WI, IL, CA)"
              },
              {
                "name": "data_type",
                "value": "",
                "type": "query",
                "description": "Filter by utility data type"
              }
            ]
          },
          "docs": "Returns a list of utility companies that WegoWise can currently import data from automatically. Useful for looking up utility_company_id values when creating meters. No authentication required."
        }
      ]
    },
